PORT=3000
# Leading zero bits for the SHA-256 registration PoW. Registration is invite-only,
# so this is light anti-abuse only. ~14 keeps on-device solving well under ~1s;
# higher values (20) make pure-JS mobile solving take 30-60s+.
POW_DIFFICULTY=14

# Database: 'sqlite' or 'postgres'
DB_TYPE=sqlite
DB_PATH=./data/messenger.db
# DATABASE_URL=postgres://faceless:password@localhost:5432/faceless

# Admin dashboard API secret (required for /api/admin/stats)
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# Logging
LOG_LEVEL=info        # debug | info | warn | error
LOG_FORMAT=json       # json | text
LOG_ICE=false         # if true, every ICE candidate is logged at INFO

# --- File storage (S3-compatible). Leave S3_BUCKET empty to disable uploads. ---
S3_ENDPOINT=s3.example.com
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=true
# Single global storage pool (total across all users) and per-file cap:
MAX_STORAGE_TOTAL_GB=10
MAX_FILE_SIZE_MB=25
